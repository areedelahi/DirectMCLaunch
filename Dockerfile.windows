FROM rust:latest

RUN apt-get update && apt-get install -y mingw-w64

RUN rustup target add x86_64-pc-windows-gnu

# eframe requires winit which for Windows needs no extra C libs,
# but we need to configure cargo to use the mingw linker
RUN mkdir -p /.cargo && echo "[target.x86_64-pc-windows-gnu]\nlinker = \"x86_64-w64-mingw32-gcc\"\n" > /.cargo/config.toml

WORKDIR /app
CMD ["cargo", "build", "--release", "--target", "x86_64-pc-windows-gnu"]
